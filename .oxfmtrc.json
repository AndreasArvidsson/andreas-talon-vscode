{
    "$schema": "./node_modules/oxfmt/configuration_schema.json",
    "tabWidth": 4,
    "printWidth": 80,
    "sortPackageJson": false,
    "sortImports": {
        "newlinesBetween": false,
        "partitionByComment": true
    },
    "ignorePatterns": ["/src/typings/treeSitter.d.ts"],

    "overrides": [
        {
            "files": ["*.yaml"],
            "options": {
                "tabWidth": 2
            }
        }
    ]
}
